{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the Nitro Sense Linux app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-minimize",
    "core:window:allow-close",
    "core:window:allow-start-dragging",
    "core:window:allow-toggle-maximize",
    "core:window:allow-maximize",
    "core:window:allow-unmaximize",
    "shell:allow-execute",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "nvidia-smi",
          "cmd": "nvidia-smi",
          "args": true
        },
        {
          "name": "pkexec-write-sysfs",
          "cmd": "pkexec",
          "args": [
            "/usr/local/bin/nitro-sense-helper",
            { "validator": ".+" },
            { "validator": ".+" }
          ]
        }
      ]
    }
  ]
}
