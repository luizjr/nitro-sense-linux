{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nitro Sense Linux",
  "version": "0.1.0",
  "identifier": "com.nitrosenselinux.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Nitro Sense Linux",
        "width": 1120,
        "height": 720,
        "minWidth": 1000,
        "minHeight": 660,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png"
    ],
    "category": "Utility",
    "shortDescription": "NitroSense replacement for Linux",
    "longDescription": "Control fans, platform profile and GPU OC on Acer Nitro AN515-58 under Linux."
  }
}
